#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Load secrets and config
set -a
source "$SCRIPT_DIR/.env"
set +a

# Clear PYTHONPATH so the venv's own packages are used, not Nix shell leakage
unset PYTHONPATH

exec "$SCRIPT_DIR/.venv/bin/python3" "$SCRIPT_DIR/server.py" "$@"
